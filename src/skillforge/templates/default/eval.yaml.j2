version: "1"

defaults:
  agent: openai
  provider: local
  trials: 5
  timeout: 300
  threshold: 0.8
  grader_model: gpt-4o

tasks:
  - name: basic-task
    instruction: |
      {{ description }}
    workspace: []
    graders:
      - type: llm_rubric
        rubric: |
          Evaluate whether the agent correctly completed the task.
          Score 1.0 for complete success, 0.5 for partial success, 0.0 for failure.
        weight: 1.0
