skill:
  name: {{ name }}
  summary: {{ description }}

settings:
  trials: 5
  timeout: 300
  threshold: 0.8

tasks:
  - name: basic-task
    instruction: |
      {{ description }}
    trigger: true
    workspace: []
    graders:
{%- for grader in graders %}
      - type: {{ grader.type }}
        weight: {{ grader.weight }}
{%- if grader.type == "llm" %}
        rubric: |
{% for line in grader.rubric.split('\n') %}          {{ line }}
{% endfor %}
{%- elif grader.type == "deterministic" %}
        run: |
{% for line in grader.run.split('\n') %}          {{ line }}
{% endfor %}
{%- endif %}
{%- endfor %}
    trials: 5
    timeout: 300
