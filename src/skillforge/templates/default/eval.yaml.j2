version: "1"

defaults:
  agent: openai
  provider: local
  trials: 5
  timeout: 300
  threshold: 0.8
  grader_model: gpt-4o

tasks:
  - name: basic-task
    instruction: |
      {{ description }}
    workspace: []
    graders:
{%- for grader in graders %}
      - type: {{ grader.type }}
        weight: {{ grader.weight }}
{%- if grader.type == "llm_rubric" %}
        rubric: |
{% for line in grader.rubric.split('\n') %}          {{ line }}
{% endfor %}
{%- elif grader.type == "deterministic" %}
        run: |
{% for line in grader.run.split('\n') %}          {{ line }}
{% endfor %}
{%- endif %}
{%- endfor %}
